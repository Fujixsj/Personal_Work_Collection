---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getProfile, getProjects } from "@/lib/content";

const profile = getProfile();
const projects = getProjects().slice(0, 3);
---

<BaseLayout title="CV" description="在线简历入口，包含个人定位、联系方式、技能方向和代表项目。" pathname="/cv">
  <Header />
  <main class="section">
    <div class="container max-w-4xl">
      <div class="flex flex-col gap-5 border-b border-[var(--border)] pb-8 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow">CV</p>
          <h1 class="mt-3 text-4xl font-semibold">{profile.name}</h1>
          <p class="mt-2 text-xl text-[var(--accent-strong)]">{profile.title}</p>
          <p class="mt-4 max-w-2xl text-[var(--muted)]">{profile.bio}</p>
        </div>
        <a class="button button-primary" href={profile.resumeUrl}>下载简历</a>
      </div>

      <section class="py-8">
        <h2 class="text-2xl font-semibold">联系方式</h2>
        <p class="mt-3 text-[var(--muted)]">{profile.email} · {profile.location}</p>
      </section>

      <section class="border-t border-[var(--border)] py-8">
        <h2 class="text-2xl font-semibold">代表项目</h2>
        <div class="mt-5 grid gap-5">
          {projects.map((project) => (
            <article class="surface rounded-lg p-5">
              <h3 class="text-xl font-semibold">{project.title}</h3>
              <p class="mt-2 text-[var(--muted)]">{project.summary}</p>
              <p class="mt-3 text-sm">角色：{project.role}</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {project.techStack.map((tech) => <span class="tag">{tech}</span>)}
              </div>
            </article>
          ))}
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
