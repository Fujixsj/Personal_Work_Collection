---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ParticleField from "@/components/ParticleField.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import TimelineList from "@/components/TimelineList.astro";
import { getFeaturedProjects, getProfile, getTimelinePreview } from "@/lib/content";

const profile = getProfile();
const projects = getFeaturedProjects();
const timeline = getTimelinePreview();
---

<BaseLayout>
  <Header />
  <main>
    <section class="hero-shell min-h-[calc(100vh-3.5rem)] border-b border-[var(--border)]">
      <ParticleField />
      <div class="container page-intro hero-content grid min-h-[calc(100vh-3.5rem)] content-center">
        <div class="grid gap-8 md:grid-cols-[120px_1fr] md:items-start">
          <img class="avatar-mark" src="/icon.jpg" alt={`${profile.name} 的头像标识`} loading="eager" />
          <div class="max-w-3xl">
            <p class="eyebrow">{profile.availability}</p>
            <h1 class="mt-4 text-4xl font-semibold leading-tight sm:text-6xl">
            {profile.name}
          </h1>
          {profile.englishName && (
            <p class="mt-2 font-mono text-sm text-[var(--muted)]">@{profile.englishName}</p>
          )}
          <p class="mt-4 text-xl text-[var(--accent-strong)]">{profile.title}</p>
            <p class="mt-6 max-w-2xl text-lg text-[var(--muted)]">{profile.bio}</p>
            <p class="mt-4 max-w-2xl text-base">{profile.tagline}</p>
            <div class="mt-8">
              <SocialLinks links={profile.socialLinks} />
            </div>
            <div class="mt-8 flex flex-wrap gap-3">
              <a class="button button-primary" href="/projects">查看项目</a>
              <a class="button button-secondary" href={profile.resumeUrl}>简历入口</a>
              <a class="button button-secondary" href="#contact">联系我</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section border-t border-[var(--border)]" id="projects">
      <div class="container">
        <div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="eyebrow">Featured Projects</p>
            <h2 class="mt-2 text-3xl font-semibold">重点项目</h2>
          </div>
          <a class="text-link text-sm" href="/projects">查看全部项目</a>
        </div>
        <div class="grid gap-5 md:grid-cols-3">
          {projects.map((project) => <ProjectCard project={project} />)}
        </div>
      </div>
    </section>

    <section class="section border-t border-[var(--border)]">
      <div class="container grid gap-8 md:grid-cols-[0.85fr_1.15fr]">
        <div>
          <p class="eyebrow">Timeline</p>
          <h2 class="mt-2 text-3xl font-semibold">最近轨迹</h2>
          <p class="mt-4 text-[var(--muted)]">按时间倒序记录项目、学习和成长节点，后续可以扩展为完整年份视图。</p>
          <a class="text-link mt-5 inline-flex text-sm" href="/timeline">查看完整时间线</a>
        </div>
        <TimelineList entries={timeline} />
      </div>
    </section>

    <section class="section border-t border-[var(--border)]" id="contact">
      <div class="container grid gap-6 md:grid-cols-[0.9fr_1.1fr]">
        <div>
          <p class="eyebrow">Contact</p>
          <h2 class="mt-2 text-3xl font-semibold">欢迎交流</h2>
        </div>
        <div>
          <p class="text-lg">正在寻找有趣的产品、前端、后端或 AI 项目合作，也欢迎关于作品集内容的反馈。</p>
          <p class="mt-3 text-[var(--muted)]">{profile.email} · {profile.location}</p>
          <div class="mt-6">
            <SocialLinks links={profile.socialLinks} />
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
