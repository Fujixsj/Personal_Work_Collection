<canvas class="particle-field" data-particle-field aria-hidden="true"></canvas>

<script>
  const canvas = document.querySelector("[data-particle-field]") as HTMLCanvasElement | null;
  const context = canvas?.getContext("2d");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (canvas && context && !reducedMotion) {
    const field = canvas;
    const drawingContext = context;
    const particles: Array<{
      x: number;
      y: number;
      vx: number;
      vy: number;
      radius: number;
      alpha: number;
    }> = [];

    const pointer = {
      x: 0,
      y: 0,
      active: false
    };

    let width = 0;
    let height = 0;
    let animationFrame = 0;
    const deviceScale = Math.min(window.devicePixelRatio || 1, 2);

    function readParticleTheme() {
      const styles = getComputedStyle(document.documentElement);
      return {
        dot: styles.getPropertyValue("--particle-dot").trim() || "239, 183, 108",
        line: styles.getPropertyValue("--particle-line").trim() || "212, 155, 85",
        lineOpacity: Number(styles.getPropertyValue("--particle-line-opacity").trim()) || 0.32,
        dotOpacityBoost: Number(styles.getPropertyValue("--particle-dot-opacity-boost").trim()) || 0.18
      };
    }

    function resize() {
      width = field.clientWidth;
      height = field.clientHeight;
      field.width = Math.floor(width * deviceScale);
      field.height = Math.floor(height * deviceScale);
      drawingContext.setTransform(deviceScale, 0, 0, deviceScale, 0, 0);

      const targetCount = Math.min(90, Math.max(38, Math.floor((width * height) / 18000)));
      particles.length = 0;

      for (let index = 0; index < targetCount; index += 1) {
        particles.push({
          x: Math.random() * width,
          y: Math.random() * height,
          vx: (Math.random() - 0.5) * 0.24,
          vy: (Math.random() - 0.5) * 0.24,
          radius: Math.random() * 1.7 + 0.7,
          alpha: Math.random() * 0.45 + 0.2
        });
      }
    }

    function drawLine(x1: number, y1: number, x2: number, y2: number, opacity: number) {
      const theme = readParticleTheme();
      drawingContext.beginPath();
      drawingContext.moveTo(x1, y1);
      drawingContext.lineTo(x2, y2);
      drawingContext.strokeStyle = `rgba(${theme.line}, ${opacity * theme.lineOpacity})`;
      drawingContext.lineWidth = 1;
      drawingContext.stroke();
    }

    function animate() {
      const theme = readParticleTheme();
      drawingContext.clearRect(0, 0, width, height);

      for (const particle of particles) {
        particle.x += particle.vx;
        particle.y += particle.vy;

        if (particle.x < -8) particle.x = width + 8;
        if (particle.x > width + 8) particle.x = -8;
        if (particle.y < -8) particle.y = height + 8;
        if (particle.y > height + 8) particle.y = -8;

        drawingContext.beginPath();
        drawingContext.arc(particle.x, particle.y, particle.radius, 0, Math.PI * 2);
        drawingContext.fillStyle = `rgba(${theme.dot}, ${Math.min(0.95, particle.alpha + theme.dotOpacityBoost)})`;
        drawingContext.fill();
      }

      for (let first = 0; first < particles.length; first += 1) {
        for (let second = first + 1; second < particles.length; second += 1) {
          const particleA = particles[first];
          const particleB = particles[second];
          const distance = Math.hypot(particleA.x - particleB.x, particleA.y - particleB.y);

          if (distance < 118) {
            drawLine(
              particleA.x,
              particleA.y,
              particleB.x,
              particleB.y,
              (1 - distance / 118) * 1
            );
          }
        }

        if (pointer.active) {
          const particle = particles[first];
          const pointerDistance = Math.hypot(particle.x - pointer.x, particle.y - pointer.y);

          if (pointerDistance < 150) {
            drawLine(particle.x, particle.y, pointer.x, pointer.y, (1 - pointerDistance / 150) * 1.25);
          }
        }
      }

      animationFrame = window.requestAnimationFrame(animate);
    }

    field.addEventListener("pointermove", (event) => {
      const rect = field.getBoundingClientRect();
      pointer.x = event.clientX - rect.left;
      pointer.y = event.clientY - rect.top;
      pointer.active = true;
    });

    field.addEventListener("pointerleave", () => {
      pointer.active = false;
    });

    window.addEventListener("resize", resize);
    resize();
    animate();

    document.addEventListener("astro:before-swap", () => {
      window.cancelAnimationFrame(animationFrame);
      window.removeEventListener("resize", resize);
    });
  }
</script>
