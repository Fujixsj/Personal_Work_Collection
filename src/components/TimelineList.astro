---
import type { TimelineEntry } from "@/types/content";

type Props = {
  entries: TimelineEntry[];
};

const { entries } = Astro.props;
---

<ol class="grid gap-6">
  {entries.map((entry) => (
    <li class="relative border-l border-[var(--border)] pl-6">
      <span class="absolute -left-[5px] top-2 h-2.5 w-2.5 rounded-full border border-[var(--background)] bg-[var(--accent)]"></span>
      <article class="grid gap-2 pb-2">
        <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
          <div>
            <p class="eyebrow">{entry.type}</p>
            <h3 class="text-lg font-semibold">{entry.title}</h3>
          </div>
          <time class="font-mono text-sm text-[var(--muted)]" datetime={entry.date}>{entry.date}</time>
        </div>
        <p class="text-sm text-[var(--muted)]">{entry.subtitle}</p>
        <p class="text-sm leading-6">{entry.description}</p>
        <div class="flex flex-wrap gap-2">
          {entry.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
        {entry.links.length > 0 && (
          <div class="flex flex-wrap gap-3">
            {entry.links.map((link) => (
              <a class="text-link text-sm" href={link.url}>
                {link.label}
              </a>
            ))}
          </div>
        )}
      </article>
    </li>
  ))}
</ol>
